@{
    ViewData["Title"] = "System Analytics";
    Layout = "_AdminLayout"; // Apka dashboard layout
}

<style>
    /* ==============================================
           ANALYTICS PAGE STYLES (FIN AI THEME)
           ============================================== */
    .page-header {
        margin-bottom: 30px;
    }

    .page-title-box h2 {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-main);
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 5px;
    }

        .page-title-box h2 i {
            color: var(--accent-green);
        }

    .page-title-box p {
        color: var(--text-muted);
        font-size: 14px;
        margin: 0;
    }

    /* Charts Grid Layout */
    .charts-grid {
        display: grid;
        grid-template-columns: 2fr 1fr; /* Line chart ko zyada jagah milegi */
        gap: 25px;
        margin-bottom: 25px;
    }

    .chart-card {
        background-color: var(--panel-bg);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        padding: 25px;
        position: relative;
    }

    .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .chart-title {
        color: var(--text-main);
        font-size: 16px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .chart-title i {
            color: var(--accent-green);
        }

    /* Quick Insight Cards */
    .insights-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 25px;
    }

    .insight-box {
        background: linear-gradient(145deg, rgba(209, 255, 39, 0.05), transparent);
        border: 1px solid rgba(209, 255, 39, 0.1);
        padding: 20px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .insight-icon {
        width: 50px;
        height: 50px;
        background: rgba(209, 255, 39, 0.1);
        color: var(--accent-green);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .insight-info h4 {
        margin: 0;
        font-size: 24px;
        font-weight: 700;
        color: var(--text-main);
    }

    .insight-info p {
        margin: 0;
        font-size: 12px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Mobile Responsive */
    @@media (max-width: 992px) {
        .charts-grid {
            grid-template-columns: 1fr;
        }

        .insights-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-header gsap-analytics">
    <div class="page-title-box">
        <h2><i class="bi bi-graph-up-arrow"></i> System Analytics Matrix</h2>
        <p>Real-time telemetry and demographic analysis of the FIN AI network.</p>
    </div>
</div>

<div class="insights-grid gsap-analytics">
    <div class="insight-box">
        <div class="insight-icon"><i class="bi bi-people"></i></div>
        <div class="insight-info">
            <h4>@ViewBag.TotalUsers</h4>
            <p>Total Network Nodes</p>
        </div>
    </div>
    <div class="insight-box" style="background: linear-gradient(145deg, rgba(255, 255, 255, 0.03), transparent); border-color: rgba(255, 255, 255, 0.05);">
        <div class="insight-icon" style="color: var(--text-main); background: rgba(255, 255, 255, 0.05);"><i class="bi bi-person-fill"></i></div>
        <div class="insight-info">
            <h4>@ViewBag.UserCount</h4>
            <p>Standard Citizens</p>
        </div>
    </div>
    <div class="insight-box" style="background: linear-gradient(145deg, rgba(255, 193, 7, 0.05), transparent); border-color: rgba(255, 193, 7, 0.1);">
        <div class="insight-icon" style="color: #ffc107; background: rgba(255, 193, 7, 0.1);"><i class="bi bi-shield-lock"></i></div>
        <div class="insight-info">
            <h4>@ViewBag.AdminCount</h4>
            <p>Admin Masters</p>
        </div>
    </div>
</div>

<div class="charts-grid gsap-analytics">

    <div class="chart-card">
        <div class="chart-header">
            <div class="chart-title"><i class="bi bi-activity"></i> Network Expansion (Current Year)</div>
        </div>
        <div style="height: 300px;">
            <canvas id="growthChart"></canvas>
        </div>
    </div>

    <div class="chart-card">
        <div class="chart-header">
            <div class="chart-title"><i class="bi bi-pie-chart"></i> Role Demographics</div>
        </div>
        <div style="height: 300px; display: flex; justify-content: center;">
            <canvas id="roleChart"></canvas>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {

            // 1. GSAP Entry Animation
            if (typeof gsap !== 'undefined') {
                gsap.from(".gsap-analytics", {
                    y: 40,
                    opacity: 0,
                    duration: 0.8,
                    stagger: 0.2,
                    ease: "power3.out"
                });
            }

            // 2. Chart.js Global Settings for Dark Theme
            Chart.defaults.color = '#8a8a93'; // text-muted
            Chart.defaults.font.family = "'Outfit', sans-serif";

            // Data backend se laye hue
            const monthlyData = [@ViewBag.MonthlyData];
            const adminCount = @ViewBag.AdminCount;
            const userCount = @ViewBag.UserCount;

            // 3. Line Chart (Growth) Setup
            const growthCtx = document.getElementById('growthChart').getContext('2d');

            // Gradient for line chart
            let gradientFill = growthCtx.createLinearGradient(0, 0, 0, 300);
            gradientFill.addColorStop(0, 'rgba(209, 255, 39, 0.5)'); // Lime green top
            gradientFill.addColorStop(1, 'rgba(209, 255, 39, 0.0)'); // Transparent bottom

            new Chart(growthCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                    datasets: [{
                        label: 'New Registrations',
                        data: monthlyData,
                        borderColor: '#d1ff27', // var(--accent-green)
                        backgroundColor: gradientFill,
                        borderWidth: 3,
                        pointBackgroundColor: '#121216',
                        pointBorderColor: '#d1ff27',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        fill: true,
                        tension: 0.4 // Smooth curves
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { color: 'rgba(255, 255, 255, 0.05)' } },
                        y: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            beginAtZero: true,
                            ticks: { stepSize: 1 }
                        }
                    }
                }
            });

            // 4. Doughnut Chart (Roles) Setup
            const roleCtx = document.getElementById('roleChart').getContext('2d');
            new Chart(roleCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Users', 'Admins'],
                    datasets: [{
                        data: [userCount, adminCount],
                        backgroundColor: [
                            'rgba(255, 255, 255, 0.1)', // Gray for users
                            '#d1ff27'                   // Lime for admins
                        ],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%', // Patla ring design
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });

        });
    </script>
}