@model IEnumerable<FinTrack_Pro.Models.User>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<style>
    /* ==============================================
           DASHBOARD COMPONENTS (CARDS & TABLE)
           ============================================== */

    /* Stats Grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 25px;
        margin-bottom: 80px;
    }

    .stat-card {
        background-color: var(--panel-bg);
        border: 1px solid var(--border-color);
        padding: 30px;
        border-radius: 20px;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s, border-color 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: rgba(209, 255, 39, 0.3); /* Lime hover effect */
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--accent-green);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .stat-card:hover::before {
            opacity: 1;
        }

    .stat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--text-muted);
        font-size: 14px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 20px;
    }

        .stat-header i {
            font-size: 20px;
            color: var(--text-main);
        }

    .stat-value {
        font-size: 40px;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1;
    }

    .accent-text {
        color: var(--accent-green);
    }

    /* Table Section */
    .table-container {
        background-color: var(--panel-bg);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        margin-top: 10px;
        padding: 30px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-title i {
            color: var(--accent-green);
        }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table th {
            text-align: left;
            padding: 15px;
            color: var(--text-muted);
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid var(--border-color);
        }

        .custom-table td {
            padding: 18px 15px;
            border-bottom: 1px solid rgba(255,255,255,0.02);
            font-size: 14px;
            color: var(--text-main);
        }

        .custom-table tr:hover td {
            background-color: rgba(255,255,255,0.01);
        }

        .custom-table tr:last-child td {
            border-bottom: none;
        }

    /* Badges */
    .badge {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .badge-admin {
        background: rgba(209, 255, 39, 0.1);
        color: var(--accent-green);
        border: 1px solid rgba(209, 255, 39, 0.2);
    }

    .badge-user {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-muted);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* Action Button */
    .btn-action {
        background: transparent;
        color: var(--text-main);
        border: 1px solid var(--border-color);
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-action:hover {
            background: var(--text-main);
            color: var(--bg-color);
        }
</style>

<div class="stats-grid">
    <div class="stat-card gsap-item">
        <div class="stat-header">
            <span>Total Citizens</span>
            <i class="bi bi-people"></i>
        </div>
        <div class="stat-value">@(ViewBag.TotalUsers ?? "0")</div>
    </div>

    <div class="stat-card gsap-item">
        <div class="stat-header">
            <span>Guild Masters</span>
            <i class="bi bi-shield-check"></i>
        </div>
        <div class="stat-value accent-text">@(ViewBag.TotalAdmins ?? "0")</div>
    </div>

    <div class="stat-card gsap-item">
        <div class="stat-header">
            <span>System Node</span>
            <i class="bi bi-hdd-network"></i>
        </div>
        <div class="stat-value" style="font-size: 28px; margin-top: 10px;">Operational</div>
    </div>
</div>

<div class="table-container gsap-item mt-5">
    <div class="section-title"><i class="bi bi-lightning-fill"></i> Recent Registrations</div>

    <table class="custom-table">
        <thead>
            <tr>
                <th>Identifier</th>
                <th>Full Name</th>
                <th>Email Address</th>
                <th>Access Level</th>
                <th>Onboard Date</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var user in Model)
                {
                    <tr>
                        <td style="color: var(--text-muted);">#@user.Id</td>
                        <td style="font-weight: 500;">@user.FullName</td>
                        <td style="color: var(--text-muted);">@user.Email</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge badge-admin"><i class="bi bi-star-fill"></i> Admin</span>
                            }
                            else
                            {
                                <span class="badge badge-user"><i class="bi bi-person-fill"></i> User</span>
                            }
                        </td>
                        <td style="color: var(--text-muted);">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <a asp-action="EditUser" asp-route-id="@user.Id" class="btn-action">Manage</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" style="text-align: center; color: var(--text-muted);">No records found in the database.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof gsap !== 'undefined') {
                // Cards aur table ki smooth entry animation
                gsap.from(".gsap-item", {
                    y: 40,
                    opacity: 0,
                    duration: 0.8,
                    stagger: 0.15,
                    ease: "power3.out",
                    delay: 0.3
                });
            }
        });
    </script>
}