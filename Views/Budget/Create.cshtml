@model FinTrack_Pro.Models.Budget
@{
    ViewData["Title"] = "Set Budget";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    /* ---------------------------------------------------
       CREATE BUDGET PREMIUM DESIGN (ftx-create-budget)
       --------------------------------------------------- */
    .ftx-create-wrapper {
        padding: 40px 20px;
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ftx-glass-form-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 24px;
        padding: 35px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
        max-width: 550px;
        width: 100%;
    }

    .ftx-form-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .ftx-form-header h2 {
        font-weight: 800;
        color: #1e293b;
        font-size: 24px;
        margin-bottom: 8px;
    }

    .ftx-form-header p {
        color: #64748b;
        font-size: 14px;
    }

    /* Input Styling */
    .ftx-input-group {
        margin-bottom: 20px;
    }

    .ftx-input-label {
        display: block;
        font-weight: 700;
        color: #475569;
        margin-bottom: 8px;
        font-size: 14px;
        padding-left: 5px;
    }

    .ftx-form-control {
        width: 100%;
        padding: 12px 18px;
        border-radius: 14px;
        border: 2px solid #e2e8f0;
        background: rgba(255, 255, 255, 0.9);
        color: #1e293b;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .ftx-form-control:focus {
        outline: none;
        border-color: #f15e36;
        box-shadow: 0 0 0 4px rgba(241, 94, 54, 0.1);
        background: #fff;
    }

    .ftx-amount-input {
        font-size: 20px;
        font-weight: 800;
        color: #f15e36;
    }

    /* Buttons */
    .ftx-btn-save {
        background: #f15e36;
        color: white;
        border: none;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        width: 100%;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(241, 94, 54, 0.25);
        margin-top: 10px;
    }

    .ftx-btn-save:hover {
        background: #d94d28;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(241, 94, 54, 0.35);
    }

    .ftx-btn-back {
        display: block;
        text-align: center;
        margin-top: 15px;
        color: #64748b;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        transition: color 0.2s;
    }

    .ftx-btn-back:hover {
        color: #1e293b;
    }

    .ftx-alert-error {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border-radius: 12px;
        padding: 12px;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 20px;
        border: 1px solid rgba(239, 68, 68, 0.2);
        display: flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="ftx-create-wrapper">
    <div class="ftx-glass-form-card">

        <div class="ftx-form-header">
            <h2>Set Monthly Budget 🎯</h2>
            <p>Define your spending limits to save more money.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="ftx-alert-error">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                @ViewBag.Error
            </div>
        }

        <form asp-action="Create" method="post">

            <div class="ftx-input-group">
                <label class="ftx-input-label">Budget Limit (PKR)</label>
                <input asp-for="Amount" type="number" step="0.01" class="ftx-form-control ftx-amount-input" placeholder="0.00" required />
            </div>

            <div class="ftx-input-group">
                <label class="ftx-input-label">Select Expense Category</label>
                <select asp-for="CategoryId" class="ftx-form-control" asp-items="ViewBag.Categories" required>
                    <option value="">-- Choose Category --</option>
                </select>
            </div>

            <div class="row">
                <div class="col-6">
                    <div class="ftx-input-group">
                        <label class="ftx-input-label">Month</label>
                        <select asp-for="Month" class="ftx-form-control">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(i)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-6">
                    <div class="ftx-input-group">
                        <label class="ftx-input-label">Year</label>
                        <input asp-for="Year" type="number" min="2024" max="2099" class="ftx-form-control" required />
                    </div>
                </div>
            </div>

            <button type="submit" class="ftx-btn-save">Set Budget Limit</button>

            <a asp-action="Index" class="ftx-btn-back">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 4px;"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Back to Budgets
            </a>
        </form>
    </div>
</div>