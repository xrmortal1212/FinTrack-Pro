@model FinTrack_Pro.Models.Category
@{
    ViewData["Title"] = "Delete Category";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .ftx-delete-wrapper {
        max-width: 450px;
        margin: 60px auto;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(239, 68, 68, 0.08); /* Soft red shadow */
        padding: 40px 30px;
        border: 1px solid #fee2e2;
        text-align: center;
    }

    .ftx-warning-icon {
        width: 64px;
        height: 64px;
        background-color: #fef2f2;
        color: #ef4444;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px auto;
    }

    .ftx-delete-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 10px;
    }

    .ftx-delete-text {
        font-size: 0.95rem;
        color: #666;
        margin-bottom: 25px;
        line-height: 1.5;
    }

    .ftx-category-highlight {
        background-color: #f8fafc;
        border: 1px dashed #cbd5e1;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
    }

        .ftx-category-highlight h5 {
            margin: 0 0 5px 0;
            color: #111;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .ftx-category-highlight span {
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            padding: 3px 8px;
            border-radius: 4px;
        }

    .badge-income {
        background-color: #dcfce7;
        color: #166534;
    }

    .badge-expense {
        background-color: #fee2e2;
        color: #991b1b;
    }

    .ftx-action-buttons {
        display: flex;
        gap: 12px;
    }

    .ftx-btn-cancel {
        flex: 1;
        padding: 12px;
        background-color: #fff;
        color: #444;
        font-size: 0.95rem;
        font-weight: 600;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        text-align: center;
        text-decoration: none;
        transition: 0.2s ease-in-out;
    }

        .ftx-btn-cancel:hover {
            background-color: #f1f5f9;
            color: #111;
        }

    .ftx-btn-danger {
        flex: 1;
        padding: 12px;
        background-color: #ef4444;
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.2s ease-in-out;
    }

        .ftx-btn-danger:hover {
            background-color: #dc2626;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
        }
</style>

<div class="container">
    <div class="ftx-delete-wrapper">

        <div class="ftx-warning-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
        </div>

        <h2 class="ftx-delete-title">Are you sure?</h2>
        <p class="ftx-delete-text">This action cannot be undone. You are about to permanently delete the following category:</p>

        <div class="ftx-category-highlight">
            <h5>@Model.Title</h5>
            @if (Model.Type == "Income")
            {
                <span class="badge-income">🟢 Income</span>
            }
            else
            {
                <span class="badge-expense">🔴 Expense</span>
            }
        </div>

        <form asp-action="Delete" method="post" class="m-0">
            <input type="hidden" name="id" value="@Model.CategoryId" />

            <div class="ftx-action-buttons">
                <a asp-action="Index" class="ftx-btn-cancel">No, Cancel</a>
                <button type="submit" class="ftx-btn-danger">Yes, Delete</button>
            </div>
        </form>

    </div>
</div>