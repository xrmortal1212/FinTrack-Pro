@* 
======================================
           ⭐ Features Section ⭐
======================================
*@

<section class="ftx-features-section gsap-fade-anim" id="features">
    
    <div class="ftx-L-lolide">
        <img src="~/images/L_svg.png" alt="L_rotating" />
    </div>

    <div class="ftx-feature-svg-wrapper">
        <svg viewBox="0 0 1000 1000" preserveAspectRatio="none" width="100%" height="100%">
            <path class="ftx-feature-scroll-path"
                  d="M 500 0
                 C 900 250, 900 450, 500 500
                 C 100 550, 100 750, 500 1000"
                  fill="none"
                  stroke="#a3e635"
                  stroke-width="20"
                  stroke-linecap="round"
                  vector-effect="non-scaling-stroke" />
        </svg>
    </div>
   

    <div class="ftx-feat-container">
        <div class="ftx-feat-left">
            <div class="ftx-img-wrapper">
                <div class="ftx-feat-img" style="background-image: url('https://i.pinimg.com/736x/d5/bc/d0/d5bcd059fb43f6bc7ee43ab5490074b0.jpg');"></div>
                <div class="ftx-feat-img" style="background-image: url('https://i.pinimg.com/1200x/55/3d/d3/553dd33c3d8440cfd8ad5bb94378df50.jpg');"></div>
                <div class="ftx-feat-img" style="background-image: url('https://i.pinimg.com/1200x/73/05/58/7305580cbf436013438cce90dfb22416.jpg');"></div>
                <div class="ftx-feat-img" style="background-image: url('https://i.pinimg.com/736x/af/83/ac/af83acf78a1965d7c86e16e0eb723a13.jpg');"></div>
            </div>
        </div>

        <div class="ftx-feat-right">
            <div class="ftx-feat-spacer"></div>

            <div class="ftx-feat-item">
                <h2 class="ftx-feat-title "><i class="bi bi-bar-chart-fill"></i> Visual Analytics</h2>
                <p class="ftx-feat-desc">Get a bird's-eye view of your finances. Our dynamic charts and graphs make it easy to understand where your money goes every month.</p>
            </div>

            <div class="ftx-feat-item">
                <h2 class="ftx-feat-title"><i class="bi bi-lightning-charge-fill"></i> Instant Tracking</h2>
                <p class="ftx-feat-desc">Log your expenses on the go. Sync your accounts to automatically categorize and track your transactions in real-time.</p>
            </div>

            <div class="ftx-feat-item">
                <h2 class="ftx-feat-title"><i class="bi bi-receipt"></i> Smart Tax Estimation</h2>
                <p class="ftx-feat-desc">Never get caught off guard during tax season. Our smart algorithm estimates your tax liabilities based on your income and expenses.</p>
            </div>

            <div class="ftx-feat-item">
                <h2 class="ftx-feat-title"><i class="bi bi-shield-lock-fill"></i> Secure & Private</h2>
                <p class="ftx-feat-desc">Your financial data is encrypted and stored securely. We use bank-level security to ensure your information remains 100% private.</p>
            </div>

            <div class="ftx-feat-spacer"></div>
        </div>
    </div>
</section>

