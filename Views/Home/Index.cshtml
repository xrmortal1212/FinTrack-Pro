<script>
    document.addEventListener("DOMContentLoaded", function () {

        // ==========================================
        // 0. GSAP PLUGINS REGISTER
        // ==========================================
        if (typeof gsap !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);
        }

        // ==========================================
        // MASTER FUNCTION CALLS (Execution Order)
        // ==========================================
        initLoader();
        initHeroAnimations();
        initHowItWorks();
        initFeatureSection();
        initFeatureScrollLine();
        initTestimonials();
        initMiscEffects();
        initTrustSection();
        initTeamSection();
        initServicesHScroll();       
        initNagiAnimation(); 
        initMobAnimation();
        initContactSection();
        initFormInteractions();
        initSpotlightEffect();
        initEmailJSForm(); // <-- Added EmailJS Form Init
        initTextHoverShine();

        // ==========================================
        // 1. HAMSTER LOADER LOGIC
        // ==========================================
        function initLoader() {
            if (typeof gsap === 'undefined') return;

            document.body.classList.add("loading-active");

            const loaderTl = gsap.timeline();

            loaderTl.to("#loader-animation-box", { opacity: 0, scale: 0.8, duration: 0.5, ease: "power2.inOut", delay: 2.0 })
                .set("#loader-welcome-text", { display: "block" })
                .to("#loader-welcome-text", { opacity: 1, y: -80, duration: 0.6, ease: "power2.out" })
                .to("#ftx-loader-screen", {
                    opacity: 0, duration: 0.8, delay: 1.0, ease: "power2.inOut",
                    onComplete: () => {
                        document.getElementById("ftx-loader-screen").style.display = "none";
                        document.body.classList.remove("loading-active");

                        gsap.to(".fade-up", {
                            y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: "power3.out"
                        });
                    }
                });
        }

        // ==========================================
        // 2. HERO SECTION CINEMATIC REVEAL & FLOATS
        // ==========================================
        function initHeroAnimations() {
            if (typeof gsap === 'undefined') return;

            gsap.set(".reveal-text", { y: "100%", opacity: 0 });

            const heroTl = gsap.timeline({ delay: 4 });

            heroTl.fromTo(".gsap-hero-badge",
                    { opacity: 0, y: -20 },
                    { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }
                )
                .to(".reveal-text",
                    { y: "0%", opacity: 1, duration: 1, stagger: 0.2, ease: "power4.out" },
                    "-=0.3"
                )
                .fromTo(".gsap-hero-desc",
                    { opacity: 0, x: 30 },
                    { opacity: 1, x: 0, duration: 0.8, ease: "power3.out" },
                    "-=0.6"
                )
                .fromTo(".gsap-hero-check span",
                    { opacity: 0, x: -15 },
                    { opacity: 1, x: 0, duration: 0.5, stagger: 0.15, ease: "power2.out" },
                    "-=0.4"
                )
                .fromTo(".gsap-hero-btn",
                    { opacity: 0, scale: 0.8, y: 20 },
                    { opacity: 1, scale: 1, y: 0, duration: 0.6, ease: "back.out(1.5)" },
                    "-=0.2"
                )
                .fromTo(".gsap-hero-showcase",
                    { opacity: 0, y: 60 },
                    { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" },
                    "-=0.4"
                )
                .fromTo(".ftx-floating-users",
                    { opacity: 0, scale: 0.5, x: -40 },
                    { opacity: 1, scale: 1, x: 0, duration: 0.7, ease: "back.out(1.2)" },
                    "-=0.4"
                )
                .fromTo(".gsap-float-card",
                    { opacity: 0, scale: 0.5, x: 40 },
                    { opacity: 1, scale: 1, x: 0, duration: 0.7, ease: "back.out(1.2)" },
                    "-=0.5"
                )
                .add(() => {
                    gsap.to(".gsap-float-card", { y: -20, duration: 3, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 0.5 });
                    gsap.to(".ftx-hero-section .ftx-spin-icon", { rotation: 360, duration: 10, ease: "linear", repeat: -1 });
                    gsap.to(".ftx-spin-icon", { rotation: 360, duration: 10, ease: "linear", repeat: -1 });
                });
        }

        // ==========================================
        // 3. HOW IT WORKS (SVG LINE DRAWING)
        // ==========================================
        function initHowItWorks() {
            if (typeof gsap === 'undefined') return;

            const path = document.querySelector('.ftx-hiw-path path');
            if (!path) return;

            const pathLength = path.getTotalLength();
            path.style.strokeDasharray = pathLength;
            path.style.strokeDashoffset = pathLength;

            const lineTl = gsap.timeline({
                scrollTrigger: {
                    trigger: ".ftx-hiw-flow-wrapper",
                    start: "top 70%",
                    end: "bottom 40%",
                    scrub: 1,
                }
            });

            lineTl.to(path, { strokeDashoffset: 0, duration: 2, ease: "none" })
                .fromTo(".ftx-card-1", { opacity: 0, scale: 0.5, y: 50 }, { opacity: 1, scale: 1, y: 0, duration: 0.5, ease: "back.out(1.5)" }, 0.2)
                .fromTo(".ftx-card-2", { opacity: 0, scale: 0.5, y: 50 }, { opacity: 1, scale: 1, y: 0, duration: 0.5, ease: "back.out(1.5)" }, 0.8)
                .fromTo(".ftx-card-3", { opacity: 0, scale: 0.5, y: 50 }, { opacity: 1, scale: 1, y: 0, duration: 0.5, ease: "back.out(1.5)" }, 1.4)
                .fromTo(".ftx-hiw-bottom-note", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.3 }, 1.8);
        }

        // ==========================================
        // 4. FEATURE SECTION SCROLL HIGHLIGHT & ROTATING 'L'
        // ==========================================
        function initFeatureSection() {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

        // --- PART 1: TEXT & IMAGE SCROLLYTELLING ---
        const featItems = gsap.utils.toArray('.ftx-feat-item');
        const featImages = gsap.utils.toArray('.ftx-feat-img');

        // Naya Gradients Array (Har item ke liye 2 colors)
        const bgGradients = [
        { c1: "#fff", c2: "#C1619E" }, // Feature 1
        { c1: "#fff", c2: "#F589BA" }, // Feature 2
        { c1: "#fff", c2: "#C672BF" }, // Feature 3
        { c1: "#fff", c2: "#598BA4" }  // Feature 4
        ];

        if (featItems.length > 0 && featImages.length > 0) {
        gsap.set(featImages[0], { opacity: 1, scale: 1 });
        gsap.set(featItems[0], { opacity: 1 });

        featItems.forEach((item, index) => {
        ScrollTrigger.create({
        trigger: item,
        start: "top center",
        end: "bottom center",
        onEnter: () => activateFeature(index),
        onEnterBack: () => activateFeature(index),
        });
        });

        function activateFeature(index) {
        gsap.to(".ftx-features-section", {
        "--grad-color-1": bgGradients[index].c1,
        "--grad-color-2": bgGradients[index].c2,
        duration: 0.8,
        ease: "power2.inOut"
        });

        featItems.forEach((el, i) => gsap.to(el, { opacity: i === index ? 1 : 0.15, duration: 0.4 }));
        featImages.forEach((img, i) => gsap.to(img, { opacity: i === index ? 1 : 0, scale: i === index ? 1 : 0.95, duration: 0.6, ease: "power2.out" }));
        }
        }

        // --- PART 2: ROTATING L-SHAPE ANIMATION ---
        const lolideObject = document.querySelector('.ftx-L-lolide');
        const featuresSection = document.querySelector('#features');

        if (lolideObject && featuresSection) {
        gsap.to(lolideObject, {
        y: () => featuresSection.offsetHeight - 250,
        rotation: 720,
        ease: "none",
        scrollTrigger: {
        trigger: featuresSection,
        start: "top center",
        end: "bottom bottom",
        scrub: 1.5
        }
        });
        }
        }

        // ==========================================
        // 5. DYNAMIC TESTIMONIALS
        // ==========================================
        function initTestimonials() {
            const testimonialsData = [
                { headline: `"My expenses are finally under control. The visual analytics are a game changer!"`, desc: "FinTrack Pro completely transformed how I manage my monthly budget. The tax estimation feature alone saved me hundreds of dollars. Highly recommended!", name: "Abdul Moiz", role: "Software Engineer" },
                { headline: `"Incredibly secure and easy to use. I instantly know where my money is going."`, desc: "I used to track my expenses on complex Excel sheets. Syncing my accounts with FinTrack Pro was seamless. It categorizes everything automatically and the UI is beautiful.", name: "Mehdi Abbas Moosani", role: "Small Business Owner" },
                { headline: `"The best financial decision I made this year. Period."`, desc: "I love the 256-bit encryption. It gives me peace of mind knowing my financial data is totally secure. The real-time tracking has helped me cut down on useless subscriptions.", name: "Rohit Gogoi", role: "Digital Marketer" }
            ];

            const userImages = document.querySelectorAll('.ftx-user-img');
            const testiWrapper = document.getElementById('ftx-testi-text-wrapper');
            const headlineEl = document.getElementById('ftx-testi-headline');
            const descEl = document.getElementById('ftx-testi-desc');
            const nameEl = document.getElementById('ftx-testi-name');
            const roleEl = document.getElementById('ftx-testi-role');

            if (!testiWrapper) return;

            userImages.forEach(img => {
                img.addEventListener('click', function () {
                    userImages.forEach(el => el.classList.remove('active'));
                    this.classList.add('active');

                    const index = this.getAttribute('data-index');
                    const data = testimonialsData[index];

                    gsap.to(testiWrapper, {
                        opacity: 0, y: 10, duration: 0.2,
                        onComplete: () => {
                            headlineEl.innerText = data.headline;
                            descEl.innerText = data.desc;
                            nameEl.innerText = data.name;
                            roleEl.innerText = data.role;
                            gsap.to(testiWrapper, { opacity: 1, y: 0, duration: 0.3, ease: "power2.out" });
                        }
                    });
                });
            });
        }

        // ==========================================
        // 6. MISC EFFECTS (Parallax & AOS)
        // ==========================================
        function initMiscEffects() {
            document.addEventListener("mousemove", (e) => {
                const x = (window.innerWidth - e.pageX) / 50;
                const y = (window.innerHeight - e.pageY) / 50;
                document.querySelectorAll('.parallax-element').forEach(el => {
                    const speed = el.getAttribute('data-speed') || 1;
                    gsap.to(el, { x: x * speed, y: y * speed, duration: 1, ease: "power1.out" });
                });
            });

            if (typeof AOS !== 'undefined') {
                AOS.init({ once: true, offset: 50 });
            }
        }

        // ==========================================
        // SCROLL UP & DOWN FADE ANIMATION
        // ==========================================
        if (typeof gsap !== 'undefined') {
            const fadeElements = gsap.utils.toArray('.gsap-fade-anim');

            fadeElements.forEach(el => {
                gsap.fromTo(el,
                    { opacity: 0, y: 50 },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        ease: "power2.out",
                        scrollTrigger: {
                            trigger: el,
                            start: "top 95%",
                            end: "bottom 5%",
                            toggleActions: "play reverse play reverse"
                        }
                    }
                );
            });
        }

        // ==========================================
        // 7. TRUST SECTION (STATS COUNTER & TEAM)
        // ==========================================
        function initTrustSection() {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

            const counters = document.querySelectorAll('.gsap-counter');

            counters.forEach(counter => {
                const target = parseInt(counter.getAttribute('data-target'));
                const prefix = counter.getAttribute('data-prefix') || '';
                const suffix = counter.getAttribute('data-suffix') || '';

                gsap.fromTo(counter,
                    { innerText: 0 },
                    {
                        innerText: target,
                        duration: 2.5,
                        ease: "power2.out",
                        scrollTrigger: { trigger: counter, start: "top 85%" },
                        snap: { innerText: 1 },
                        onUpdate: function() {
                            const currentNum = Math.ceil(this.targets()[0].innerText);
                            counter.innerText = prefix + currentNum.toLocaleString() + suffix;
                        }
                    }
                );
            });

            gsap.fromTo(".ftx-team-card",
                { opacity: 0, y: 60 },
                {
                    opacity: 1, y: 0, duration: 0.8, stagger: 0.2, ease: "back.out(1.2)",
                    scrollTrigger: { trigger: ".ftx-team-grid", start: "top 80%" }
                }
            );
        }

    // ==========================================
    // 8. CONTACT & FOOTER SECTION ANIMATION
    // ==========================================
    function initContactSection() {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    // 1. Path aur Arrow ko GSAP ke liye tayar karna
    const path = document.querySelector('.ftx-journey-path .animated-path');
    const arrow = document.querySelector('.ftx-journey-path .arrow-head');

    if (path) {
    const pathLen = path.getTotalLength();
    // Path ko bilkul hide kar diya initial state mein
    gsap.set(path, { strokeDasharray: pathLen, strokeDashoffset: pathLen });
    }
    if (arrow) {
    gsap.set(arrow, { opacity: 0 }); // Arrow ko initially hide kar diya
    }

    // 2. Stars ki continuous rotation (ye hamesha chalti rahegi)
    gsap.to(".ftx-star-circle", {
    rotation: 360,
    duration: 8,
    ease: "none", // Linear movement
    repeat: -1    // Infinite loop
    });

    // 3. Scroll Trigger Timeline
    const contactTl = gsap.timeline({
    scrollTrigger: {
    trigger: ".ftx-contact-wrapper",
    start: "top 80%",
    toggleActions: "play none none reverse"
    }
    });

    // Existing Text Animations aur nayi Path animations
    contactTl.fromTo(".ftx-contact-wrapper .ftx-version-badge",
    { opacity: 0, y: -20 },
    { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" }
    )
    .fromTo(".ftx-contact-wrapper .ftx-hero-title",
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" },
    "-=0.3"
    )
    // 🔥 NAYA: Star container ka fade-in aur scale up
    .fromTo(".ftx-rotating-stars",
    { opacity: 0, scale: 0.5 },
    { opacity: 1, scale: 1, duration: 0.6, ease: "back.out(1.5)" },
    "-=0.4"
    )
    // 🔥 NAYA: Line Draw Animation
    .to(path, {
    strokeDashoffset: 0, // Line draw ho rahi hai
    duration: 2,
    ease: "power2.out"
    }, "-=0.2")
    // 🔥 NAYA: Arrow Fade In jab line poori hone wali ho
    .to(arrow, {
    opacity: 1,
    duration: 0.4,
    ease: "power1.out"
    }, "-=0.3")
    .fromTo(".ftx-info-col .ftx-info-block",
    { opacity: 0, x: -40 },
    { opacity: 1, x: 0, duration: 0.6, stagger: 0.2, ease: "power2.out" },
    "-=1.5" // Taki text form pichli animation ke sath sath hi aana shuru ho jaye
    )
    .fromTo(".ftx-form-col form > *",
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.5, stagger: 0.1, ease: "power2.out" },
    "-=1.2"
    )
    .fromTo(".ftx-footer-huge h2",
    { opacity: 0, scale: 0.9, y: 30 },
    { opacity: 1, scale: 1, y: 0, duration: 0.8, stagger: 0.2, ease: "back.out(1.2)" },
    "-=0.5"
    )
    .fromTo([".ftx-footer-details > div", ".ftx-footer-bottom > div"],
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.5, stagger: 0.1, ease: "power2.out" },
    "-=0.4"
    );
    }

        // ==========================================
        // 9. TEAM & ABOUT SECTION ANIMATION
        // ==========================================
        function initTeamSection() {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

            gsap.fromTo(".ftx-team-section .ftx-version-badge",
                { opacity: 0, y: -30 },
                {
                    opacity: 1, y: 0, duration: 0.8, ease: "power2.out",
                    scrollTrigger: {
                        trigger: ".ftx-team-section",
                        start: "top 85%",
                        toggleActions: "play none none reverse"
                    }
                }
            );

            gsap.fromTo(".ftx-stat-box",
                { opacity: 0, y: 40, scale: 0.9 },
                {
                    opacity: 1, y: 0, scale: 1, duration: 0.6, stagger: 0.2, ease: "back.out(1.2)",
                    scrollTrigger: {
                        trigger: ".ftx-stats-container",
                        start: "top 80%",
                        toggleActions: "play none none reverse"
                    }
                }
            );

            gsap.fromTo(".ftx-team-container .ftx-section-header > *",
                { opacity: 0, y: 30 },
                {
                    opacity: 1, y: 0, duration: 0.6, stagger: 0.15, ease: "power3.out",
                    scrollTrigger: {
                        trigger: ".ftx-team-container",
                        start: "top 85%",
                        toggleActions: "play none none reverse"
                    }
                }
            );
        }

        // ==========================================
        // 🔦 10. SPOTLIGHT EFFECT ON SCROLL
        // ==========================================
        function initSpotlightEffect() {
            const teamSection = document.getElementById('teamSection');

            if (!teamSection) return;

            const lightObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        teamSection.classList.add('light-is-on');
                    } else {
                        teamSection.classList.remove('light-is-on');
                    }
                });
            }, {
                threshold: 0.2
            });

            lightObserver.observe(teamSection);
        }

        // ==========================================
        // 11. FORM INPUTS GSAP FOCUS ANIMATION
        // ==========================================
        function initFormInteractions() {
            if (typeof gsap === 'undefined') return;

            const inputs = document.querySelectorAll('.ftx-input');

            inputs.forEach(input => {
                const group = input.closest('.ftx-form-group');
                if (!group) return;

                const label = group.querySelector('.ftx-label-sub');

                input.addEventListener('focus', () => {
                    if (label) {
                        gsap.to(label, {
                            color: "#97C9E1",
                            x: 5,
                            duration: 0.3,
                            ease: "power2.out"
                        });
                    }
                    gsap.to(input, { borderBottomColor: "#97C9E1", duration: 0.3 });
                });

                input.addEventListener('blur', () => {
                    if (label) {
                        gsap.to(label, {
                            color: "#ffffff",
                            x: 0,
                            duration: 0.3,
                            ease: "power2.out"
                        });
                    }

                    if (!input.value.trim()) {
                        gsap.to(input, { borderBottomColor: "#999", duration: 0.3 });
                    } else {
                        gsap.to(input, { borderBottomColor: "#ffffff", duration: 0.3 });
                    }
                });
            });
        }

        // ==========================================
        // 12. FEATURE SECTION SVG SCROLL LINE (Updated)
        // ==========================================
        function initFeatureScrollLine() {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

            // Pehle check karein ke path exist karta hai
            const scrollPath = document.querySelector(".ftx-feature-scroll-path");

            if (scrollPath) {
                // 1. Path ki total length calculate karein
                const pathLength = scrollPath.getTotalLength();

                // 2. Line ko initial state mein bilkul gayab (hide) kar dein
                gsap.set(scrollPath, {
                    strokeDasharray: pathLength,
                    strokeDashoffset: pathLength
                });

                // 3. ScrollTrigger lagayen jo scroll ke sath line ko draw kare
                gsap.to(scrollPath, {
                    strokeDashoffset: 0, // 0 matlab poori line draw ho gayi
                    ease: "none",
                    scrollTrigger: {
                        trigger: ".ftx-features-section", // Aapki section ki ID
                        start: "top center",  // Jab section screen ke center tak pohanche
                        end: "bottom center", // Jab section khatam hone lage
                        scrub: 1,             // Smooth drawing delay (1 second lagta hai smooth hone me)
                    }
                });
            }
        }

        // ==========================================
        // 13. EMAILJS FORM SUBMISSION
        // ==========================================
        function initEmailJSForm() {
            const contactForm = document.getElementById('ftx-contact-form');
            if (!contactForm) return; // Prevent errors if form isn't on the page

            contactForm.addEventListener('submit', function(event) {
                event.preventDefault(); // Page refresh hone se rokega

                const btn = document.getElementById('ftx-submit-btn');
                const originalText = btn.innerText;
                btn.innerText = 'Sending...'; // Button ki state change kar rahe hain

                // Aapki Service ID aur Template ID
                emailjs.sendForm('service_seouurt', 'template_l6718wq', this)
                    .then(function() {
                        btn.innerText = 'Message Sent! ✅';
                        contactForm.reset(); // Form clear kar dega

                        // 3 seconds baad button wapis "Submit" ho jayega
                        setTimeout(() => {
                            btn.innerText = originalText;
                        }, 3000);

                    }, function(error) {
                        btn.innerText = 'Failed to Send ❌';
                        console.log('FAILED...', error);

                        // 3 seconds baad button wapis normal ho jayega
                        setTimeout(() => {
                            btn.innerText = originalText;
                        }, 3000);
                    });
            });
        }

        // ==========================================
        // 16. SERVICES HORIZONTAL SCROLL (CARDS)
        // ==========================================
        function initServicesHScroll() {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

        const section = document.querySelector('.ftx-services-hscroll-section');
        const track = document.querySelector('.ftx-sh-cards-track');

        if (!section || !track) return;

        // Mobile pe agar ap isey vertical rakhna chahein toh return kar dein,
        // lakin modern sites mobile pe bhi horizontal scroll (swipe) pasand karti hain.
        const isMobile = window.innerWidth <= 768;

        if (isMobile) {
        // Mobile par hum GSAP scroll hata dete hain aur CSS me native scrolling allow karte hain
        track.style.overflowX = 'auto';
        track.style.scrollSnapType = 'x mandatory';
        const cards = document.querySelectorAll('.ftx-sh-card');
        cards.forEach(card => card.style.scrollSnapAlign = 'center');
        // Hide scrollbar for clean UI on mobile
        track.style.scrollbarWidth = 'none';
        return;
        }

        // Amount to scroll left
        function getScrollAmount() {
        let trackWidth = track.scrollWidth;
        return -(trackWidth - window.innerWidth);
        }

        const tween = gsap.to(track, {
        x: getScrollAmount,
        ease: "none"
        });

        ScrollTrigger.create({
        trigger: section,
        start: "top 10%", // Jab section top se thora neechay ho tab pin ho
        end: () => `+=${getScrollAmount() * -1}`, // Jitni lambi line hai utni der pin rakho
        pin: true,
        animation: tween,
        scrub: 1, // Smooth scrolling effect
        invalidateOnRefresh: true
        });
        }

        // ==========================================
        // TEXT GRADIENT HOVER ANIMATION (FIXED)
        // ==========================================
        function initTextHoverShine() {
        if (typeof gsap === 'undefined') return;

        const textElements = document.querySelectorAll('#ftx-gradient-text, .ftx-hover-gradient');

        textElements.forEach(text => {
        // Har text element ke liye ek ruki hui (paused) timeline banayen
        let shineAnim = gsap.to(text, {
        backgroundPosition: "100% 0%",
        duration: 0.8, // Speed thori fast kardi taake snappy lage
        ease: "power2.inOut",
        paused: true // Animation start mein ruki rahegi
        });

        // Jab Mouse aaye, toh aage ki taraf chale
        text.addEventListener('mouseenter', () => {
        shineAnim.play();
        });

        // Jab Mouse hate, toh wapas peeche (normal state) mein chali jaye
        text.addEventListener('mouseleave', () => {
        shineAnim.reverse();
        });
        });
        }

        

        // ==========================================
        // 2. MOB IMAGE FLICKER + ZOOM ANIMATION (FIXED)
        // ==========================================
        function initMobAnimation() {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

        const mobImg = document.querySelector('.ftx-mob');
        const teamSection = document.querySelector('#teamSection');

        if (!mobImg || !teamSection) return;

        // Mobile aur Desktop ke hisaab se opacity set karna
        const isMobile = window.innerWidth <= 768;
        const targetOpacity = isMobile ? 0.15 : 0.8;

        // GSAP Timeline banayen
        const flickerTl = gsap.timeline({
        scrollTrigger: {
        trigger: teamSection,
        start: "top 75%", // Jab section screen me thora zyada dakhil ho jaye tab on ho
        toggleActions: "play none none none"
        }
        });

        // Flicker Sequence (Ek ke baad ek chalega)
        flickerTl.to(mobImg, { opacity: targetOpacity, scale: 0.9, duration: 0.05 })
        .to(mobImg, { opacity: 0.1, duration: 0.05 })
        .to(mobImg, { opacity: targetOpacity, duration: 0.1 })
        .to(mobImg, { opacity: 0.2, duration: 0.05 })
        .to(mobImg, { opacity: 0, duration: 0.1 })
        .to(mobImg, { opacity: targetOpacity, scale: 1.05, duration: 0.1 }) // Pop out
        .to(mobImg, { opacity: 0.4, duration: 0.05 })
        .to(mobImg, { opacity: targetOpacity, scale: 1, duration: 0.2 }); // Normal state
        }

        // ==========================================
        // 1. NAGI IMAGE ANIMATION (SLIDE IN + FLOAT)
        // ==========================================
        function initNagiAnimation() {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

        const nagiImg = document.querySelector('.ftx-nagi');
        if (!nagiImg) return;

        // Mobile par opacity check karne ke liye
        const isMobile = window.innerWidth <= 768;
        const targetOpacity = isMobile ? 0.3 : 1;

        // Step 1: Slide In From Left
        gsap.fromTo(nagiImg,
        { x: -150, opacity: 0 }, // Shuru me 150px left aur gayab
        {
        x: 0,
        opacity: targetOpacity,
        duration: 1.5,
        ease: "power3.out",
        scrollTrigger: {
        trigger: nagiImg.parentElement, // Jis section me Nagi hai, wo trigger banega
        start: "top 70%",
        toggleActions: "play none none reverse"
        }
        }
        );

        // Step 2: Continuous Floating Effect (Hawa me tairna)
        gsap.to(nagiImg, {
        y: -15, // 15px upar jayega
        duration: 2,
        repeat: -1, // Hamesha chalta rahega
        yoyo: true, // Wapas aayega (Up & Down)
        ease: "sine.inOut"
        });
        }

    });
</script>