@using FinTrack_Pro.Data
@inject ApplicationDbContext _context
@{
    // 1. Logged-in admin ka data nikalna
    var userEmail = User.Identity?.Name;
    var currentUser = _context.Users.FirstOrDefault(u => u.Email == userEmail);

    // Agar authentication setup alag hai aur user nahi milta, toh pehla admin utha lein (fallback)
    if (currentUser == null)
    {
        currentUser = _context.Users.FirstOrDefault(u => u.Role == "Admin");
    }

    string adminName = currentUser?.FullName ?? "Admin Console";
    string initial = !string.IsNullOrEmpty(adminName) ? adminName.Substring(0, 1).ToUpper() : "A";
    string avatarSrc = currentUser?.ProfilePicturePath ?? "";

    // 2. Current Page ka pata lagana (Sidebar Highlight karne ke liye)
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FIN AI Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

    <style>
        /* ==============================================
                           FIN AI DASHBOARD THEME
                           ============================================== */
        :root {
            --bg-color: #0b0b0d;
            --panel-bg: #121216;
            --text-main: #ffffff;
            --text-muted: #8a8a93;
            --accent-green: #d1ff27; /* Neon Lime */
            --border-color: rgba(255, 255, 255, 0.05);
            --font-main: 'Outfit', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-main);
            background-color: var(--bg-color);
            color: var(--text-main);
            overflow: hidden; /* Prevent full page scroll, scroll main instead */
            display: flex;
            height: 100vh;
        }

        /* Ambient Glow */
        .bg-glow {
            position: absolute;
            top: -10%;
            left: 30%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(209, 255, 39, 0.03) 0%, transparent 60%);
            z-index: 0;
            pointer-events: none;
        }

        /* ================= SIDEBAR ================= */
        .admin-sidebar {
            width: 260px;
            background-color: var(--panel-bg);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            z-index: 10;
        }

        .logo {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 50px;
            padding-left: 10px;
        }

            .logo .dot {
                width: 8px;
                height: 8px;
                background-color: var(--accent-green);
                border-radius: 50%;
                display: inline-block;
            }

        .sidebar-menu {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1;
        }

            .sidebar-menu a {
                display: flex;
                align-items: center;
                gap: 15px;
                padding: 14px 18px;
                color: var(--text-muted);
                text-decoration: none;
                font-size: 15px;
                font-weight: 500;
                border-radius: 12px;
                transition: all 0.3s;
            }

                .sidebar-menu a:hover {
                    color: var(--text-main);
                    background: rgba(255,255,255,0.03);
                }

            .sidebar-menu li.active a {
                background: rgba(209, 255, 39, 0.05);
                color: var(--accent-green);
                border-left: 3px solid var(--accent-green);
            }

        .sidebar-bottom {
            margin-top: auto;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            padding: 14px;
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            cursor: pointer;
            font-family: inherit;
            font-size: 14px;
            transition: 0.3s;
        }

            .logout-btn:hover {
                color: #ff4757;
                border-color: rgba(255, 71, 87, 0.3);
                background: rgba(255, 71, 87, 0.05);
            }

        /* ================= MAIN CONTENT AREA ================= */
        .admin-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            position: relative;
            z-index: 5;
            overflow-y: auto;
        }

            .admin-main::-webkit-scrollbar {
                width: 6px;
            }

            .admin-main::-webkit-scrollbar-track {
                background: var(--bg-color);
            }

            .admin-main::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.1);
                border-radius: 10px;
            }

        .top-navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 25px 40px;
            border-bottom: 1px solid var(--border-color);
            background: rgba(11, 11, 13, 0.9);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 20;
        }

        .nav-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-main);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 15px;
        }

            .user-profile span {
                font-size: 14px;
                font-weight: 500;
                color: var(--text-muted);
            }

        .avatar {
            width: 40px;
            height: 40px;
            background: var(--accent-green);
            color: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-weight: 700;
            overflow: hidden; /* Image gol karne ke liye zaroori hai */
            border: 2px solid var(--panel-bg);
        }

            .avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .content-wrapper {
            padding: 40px;
        }
    </style>
</head>
<body>
    <div class="bg-glow"></div>

    <aside class="admin-sidebar" id="gsap-sidebar">
        <div class="logo">FIN AI <span class="dot"></span></div>
        <ul class="sidebar-menu">
            <li class="@(currentAction == "Index" ? "active" : "")"><a asp-action="Index"><i class="bi bi-grid-fill"></i> Dashboard</a></li>
            <li class="@(currentAction == "UsersList" ? "active" : "")"><a asp-action="UsersList"><i class="bi bi-people-fill"></i> Users</a></li>
            <li class="@(currentAction == "Analytics" ? "active" : "")"><a asp-action="Analytics"><i class="bi bi-activity"></i> Analytics</a></li>
            <li class="@(currentAction == "Settings" ? "active" : "")"><a asp-action="Settings"><i class="bi bi-gear-fill"></i> Settings</a></li>
        </ul>
        <div class="sidebar-bottom">
            <a asp-controller="Home" asp-action="Index" style="text-decoration:none;">
                <button class="logout-btn"><i class="bi bi-box-arrow-left"></i> Return to Site</button>
            </a>
        </div>
    </aside>

    <main class="admin-main">
        <header class="top-navbar" id="gsap-topbar">
            <div class="nav-title">@ViewData["Title"]</div>
            <div class="user-profile">
                <span>@adminName</span>
                <div class="avatar">
                    @if (!string.IsNullOrEmpty(avatarSrc))
                    {
                        <img src="@avatarSrc" alt="Admin Profile" />
                    }
                    else
                    {
                        @initial
                    }
                </div>
            </div>
        </header>

        <div class="content-wrapper">
            @RenderBody()
        </div>
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof gsap !== 'undefined') {
                gsap.from("#gsap-sidebar", { x: -50, opacity: 0, duration: 0.8, ease: "power3.out" });
                gsap.from("#gsap-topbar", { y: -20, opacity: 0, duration: 0.8, delay: 0.2, ease: "power3.out" });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>