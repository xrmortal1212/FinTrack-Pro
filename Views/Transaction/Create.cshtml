@model FinTrack_Pro.Models.Transaction
@{
    ViewData["Title"] = "Add Transaction";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    /* =========================================
           FinTrack Glassmorphism Form Design
           ========================================= */
    .ft-transaction-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 15px;
        
        border-radius: 24px;
        margin-top: 20px;
    }

    .ft-glass-card {
        background: rgba(255, 255, 255, 0.25);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
        border-radius: 24px;
        padding: 40px;
        width: 100%;
        max-width: auto;
    }

    .ft-glass-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .ft-glass-header h4 {
            margin: 0;
            font-weight: 700;
            color: #1e293b;
            font-size: 24px;
            letter-spacing: -0.5px;
        }

        .ft-glass-header p {
            color: #64748b;
            font-size: 14px;
            margin-top: 5px;
        }

    .ft-glass-form-group {
        margin-bottom: 24px;
    }

    .ft-glass-label {
        display: block;
        font-weight: 600;
        color: #334155;
        margin-bottom: 8px;
        font-size: 14px;
    }

    /* Standard Glass Input */
    .ft-glass-input, .ft-glass-select {
        width: 100%;
        background: rgba(255, 255, 255, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.6);
        color: #1e293b;
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 15px;
        transition: all 0.3s ease;
        outline: none;
    }

        .ft-glass-input:focus, .ft-glass-select:focus {
            background: rgba(255, 255, 255, 0.8);
            border-color: #f15e36;
            box-shadow: 0 0 0 4px rgba(241, 94, 54, 0.1);
        }

    /* Special Amount Input */
    .ft-amount-wrapper {
        position: relative;
    }

    .ft-currency-symbol {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 24px;
        font-weight: 700;
        color: #94a3b8;
    }

    .ft-amount-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.6);
        border: 2px solid transparent;
        color: #1e293b;
        padding: 16px 20px 16px 60px; /* Space for Rs. */
        border-radius: 16px;
        font-size: 28px;
        font-weight: 700;
        transition: all 0.3s ease;
        outline: none;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
    }

        .ft-amount-input:focus {
            background: rgba(255, 255, 255, 0.9);
            border-color: #f15e36;
            box-shadow: 0 8px 16px rgba(241, 94, 54, 0.1);
        }

    /* Buttons */
    .ft-btn-save {
        width: 100%;
        background: #10b981; /* Success Green */
        color: white;
        border: none;
        padding: 14px;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

        .ft-btn-save:hover {
            background: #059669;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(16, 185, 129, 0.4);
        }

    .ft-btn-back {
        display: block;
        width: 100%;
        text-align: center;
        background: rgba(255, 255, 255, 0.4);
        color: #475569;
        border: 1px solid rgba(255, 255, 255, 0.5);
        padding: 12px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        margin-top: 12px;
        transition: all 0.3s ease;
    }

        .ft-btn-back:hover {
            background: rgba(255, 255, 255, 0.8);
            color: #1e293b;
        }

    /* Select Dropdown Styling */
    select.ft-glass-select option {
        background: #ffffff;
        color: #1e293b;
    }
</style>

<div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">
        <div class="ft-transaction-wrapper">

            <div class="ft-glass-card">
                <div class="ft-glass-header">
                    <h4>Add New Transaction</h4>
                    <p>Track your incoming and outgoing finances</p>
                </div>

                <form asp-action="Create" method="post">

                    <div class="ft-glass-form-group">
                        <label class="ft-glass-label">Amount</label>
                        <div class="ft-amount-wrapper">
                            <span class="ft-currency-symbol">Rs</span>
                            <input asp-for="Amount" type="number" step="0.01" class="ft-amount-input" placeholder="0.00" required />
                        </div>
                    </div>

                    <div class="ft-glass-form-group">
                        <label class="ft-glass-label">Category</label>
                        <select asp-for="CategoryId" class="ft-glass-select" asp-items="ViewBag.Categories" required>
                            <option value="">-- Select a Category --</option>
                        </select>
                    </div>

                    <div class="ft-glass-form-group">
                        <label class="ft-glass-label">Date</label>
                        <input asp-for="Date" type="date" class="ft-glass-input" required />
                    </div>

                    <div class="ft-glass-form-group">
                        <label class="ft-glass-label">Description (Optional)</label>
                        <input asp-for="Description" class="ft-glass-input" placeholder="e.g. Bought groceries from supermarket" />
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="ft-btn-save">Save Transaction</button>
                        <a asp-action="Index" class="ft-btn-back">Back to List</a>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>